# --- Node / Electron ---
node_modules/
frontend/dist/
frontend/dist-electron/
frontend/out/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- PyInstaller build output ---
backend/build/
backend/dist/
*.spec.bak

# --- Editor / OS ---
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# --- Secrets / local config ---
.env
.env.*
!.env.example
*.pem
*.key
secrets.json
credentials.json

# --- Wordlists / large data ---
# rockyou and friends are bundled at build time via PyInstaller; they should
# never live in git.
backend/wordlists/rockyou.txt
backend/wordlists/rockyou.txt.gz
backend/wordlists/*.txt.gz

# --- Standalone CLI scan output (scripts/ writes here) ---
scans/

# --- Local idea capture (stik CLI writes here) ---
ideas/

# --- Local-only notes / bug backlog (never committed) ---
notes/

# Launch prep — personal drafts, not project docs
/launch/
