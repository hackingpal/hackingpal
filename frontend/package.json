{
  "name": "myhackingpal",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "description": "MyHackingPal — security-research desktop app (Electron + FastAPI).",
  "homepage": "https://github.com/adamsjack/myhackingpal",
  "author": {
    "name": "Jack Adams-Lovell",
    "email": "adamsjack711@gmail.com"
  },
  "scripts": {
    "dev": "vite",
    "dev:electron": "wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .",
    "dev:all": "concurrently -k -n vite,electron -c blue,magenta \"npm run dev\" \"npm run dev:electron\"",
    "build": "tsc && vite build",
    "build:backend": "cd ../backend && pyinstaller network-tools-backend.spec --noconfirm",
    "build:all": "npm run build:backend && npm run build",
    "dist": "npm run build:all && electron-builder",
    "dist:dir": "npm run build:all && electron-builder --dir",
    "dist:mac": "npm run build:all && electron-builder --mac",
    "dist:win": "npm run build:all && electron-builder --win",
    "dist:linux": "npm run build:all && electron-builder --linux",
    "preview": "vite preview",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^33.0.2",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.myhackingpal.app",
    "productName": "MyHackingPal",
    "asar": true,
    "directories": {
      "buildResources": "build",
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "dist/**/*",
      "package.json"
    ],
    "mac": {
      "target": {
        "target": "dir",
        "arch": [
          "arm64"
        ]
      },
      "category": "public.app-category.utilities",
      "icon": "build/icon.icns",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "extraResources": [
        {
          "from": "../backend/dist/network-tools-backend",
          "to": "backend/network-tools-backend"
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "extraResources": [
        {
          "from": "../backend/dist/network-tools-backend",
          "to": "backend/network-tools-backend"
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "category": "Network",
      "maintainer": "Jack Adams-Lovell <adamsjack711@gmail.com>",
      "extraResources": [
        {
          "from": "../backend/dist/network-tools-backend",
          "to": "backend/network-tools-backend"
        }
      ]
    }
  }
}
