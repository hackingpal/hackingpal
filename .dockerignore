# --- VCS / editor ---
.git/
.github/
.gitignore
.idea/
.vscode/
.DS_Store

# --- Frontend ---
# Source is needed for the multi-stage build (Node stage compiles the React
# UI; final image only carries the dist/ output). Excludes below skip the
# heavy generated artifacts so the build context stays small.
frontend/node_modules/
frontend/dist/
frontend/dist-electron/
frontend/build/

# --- Python build/cache ---
**/__pycache__/
**/*.py[cod]
**/*.egg-info/
backend/build/
backend/dist/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- PyInstaller spec output ---
*.spec.bak

# --- Repo-level docs / scripts not needed in image ---
README.md
scripts/
shells/

# --- Secrets / local config (defense in depth) ---
.env
.env.*
*.pem
*.key
secrets.json
credentials.json
