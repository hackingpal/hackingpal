# --- VCS / editor ---
.git/
.github/
.gitignore
.idea/
.vscode/
.DS_Store

# --- Frontend (not needed for backend image) ---
frontend/

# --- Python build/cache ---
**/__pycache__/
**/*.py[cod]
**/*.egg-info/
backend/build/
backend/dist/
.venv/
venv/
env/
